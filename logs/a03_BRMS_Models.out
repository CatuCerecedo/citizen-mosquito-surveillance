+                       prior = set_prior("cauchy(0,2.5)", class="b"),
+                       family = bernoulli(link = "logit"),
+                       iter = iteret,
+                       warmup = wup,
+                       chains = nchains,
+                       cores = nchains,
+                       backend = "cmdstanr",
+                       threads = threading(threads_per_chain),
+                       control = list(adapt_delta = 0.99))
